    <!-- * App Bottom Menu -->

    <!-- ========= JS Files =========  -->
    <!-- Bootstrap -->
    <script src="assets/js/lib/bootstrap.bundle.min.js"></script>
    <!-- Ionicons (self-hosted sprite) -->
    <script src="assets/js/ion-icon.js" defer></script>
    <!-- Splide -->
    <script src="assets/js/plugins/splide/splide.min.js"></script>
    <!-- i18n inline data + loader -->
    <script src="assets/js/prefs.js"></script>
    {% i18nDataScript %}
    <script src="assets/js/i18n.js"></script>
    <!-- Base Js File -->
    <script src="assets/js/base.js"></script>
    <!-- Wallet Connect -->
    <script src="assets/js/wallet-connect.js"></script>
    <!-- UTM attribution from directory listings -->
    <script src="assets/js/utm.js"></script>
    <!-- Offline Indicator -->
    <script src="assets/js/offline.js"></script>
    <!-- Telegram BackButton -->
    <script src="assets/js/back-button.js"></script>
    <script>
        wireBackButton();

        // Sync the toggle to the active language after translations load
        document.addEventListener('i18n:applied', function(e) {
            document.getElementById('languageSwitch').checked = (e.detail.lang === 'ru');
        });

        document.getElementById('languageSwitch').addEventListener('change', function() {
            i18n.setLang(this.checked ? 'ru' : 'en');
        });

        i18n.init();
    </script>
    <!-- Haptic Feedback -->
    <script src="assets/js/haptic.js"></script>
    <script>
        // Tab-bar taps
        document.querySelectorAll('.appBottomMenu .item').forEach(function (el) {
            el.addEventListener('click', function () { haptic.impact('light'); });
        });
        // Settings toggles
        document.getElementById('darkmodeSwitch').addEventListener('change', function () {
            haptic.selection();
        });
        document.getElementById('languageSwitch').addEventListener('change', function () {
            haptic.selection();
        });
        document.getElementById('notificationsSwitch').addEventListener('change', function () {
            haptic.selection();
        });
        document.getElementById('leaderboardOptinSwitch').addEventListener('change', function () {
            haptic.selection();
        });
    </script>
    <script>
        var i18nWallet = {
            connectBtn: '{{ locales.en.wallet_connect_btn }}',
            disconnectBtn: '{{ locales.en.wallet_disconnect_btn }}'
        };

        document.addEventListener('i18n:applied', function(e) {
            var t = e.detail.t || {};
            i18nWallet.connectBtn = t.wallet_connect_btn || i18nWallet.connectBtn;
            i18nWallet.disconnectBtn = t.wallet_disconnect_btn || i18nWallet.disconnectBtn;
        });

        function updateSettingsWalletUI(state) {
            var statusEl = document.getElementById('wallet-settings-status');
            var btnEl = document.getElementById('wallet-settings-btn');
            var btnLabelEl = document.getElementById('wallet-settings-btn-label');
            if (!statusEl || !btnEl || !btnLabelEl) return;

            if (state && state.connected && state.address) {
                var short = WalletConnect.shortenAddress(state.address);
                var balLine = state.balance != null ? ' · ' + state.balance + ' TON' : '';
                statusEl.textContent = short + balLine;
                btnLabelEl.textContent = i18nWallet.disconnectBtn;
                btnEl.className = 'btn btn-danger btn-sm rounded';
                btnEl.onclick = function() { WalletConnect.disconnect(); };
            } else {
                statusEl.textContent = i18nWallet.connectBtn;
                btnLabelEl.textContent = i18nWallet.connectBtn;
                btnEl.className = 'btn btn-primary btn-sm rounded';
                btnEl.onclick = function() { WalletConnect.connect(); };
            }
        }

        WalletConnect.onChange(updateSettingsWalletUI);
        WalletConnect.init('tonconnect-manifest.json', {
            sdkUrl: 'assets/js/vendor/tonconnect-ui.min.js',
            lazy: true
        });
    </script>
    <!-- Address Book -->
    <script src="assets/js/address-book.js"></script>
    <script>
        AddressBook.initManage('{{ locales.en.ab_chain }}', {
            ab_empty: '{{ locales.en.ab_empty }}',
            ab_edit: '{{ locales.en.ab_edit }}',
            ab_remove: '{{ locales.en.ab_remove }}',
            ab_edit_label_prompt: '{{ locales.en.ab_edit_label_prompt }}'
        });
    </script>
    <!-- * Address Book -->
    <!-- Telegram SettingsButton - hide on settings page to avoid recursion -->
    <script src="assets/js/settings-button.js"></script>
    <script>hideSettingsButton();</script>


</body>

</html>
