    <script>
        {% if activePage == 'bridge' %}
        var i18nWallet = {
            connectBtn: '{{ t.wallet_connect_btn }}',
            disconnectBtn: '{{ t.wallet_disconnect_btn }}',
            prefillHalf: '{{ t.wallet_prefill_half }}'
        };
        var _walletBalance = null;

        document.addEventListener('i18n:applied', function(e) {
            var t = e.detail.t || {};
            i18nWallet.connectBtn = t.wallet_connect_btn || i18nWallet.connectBtn;
            i18nWallet.disconnectBtn = t.wallet_disconnect_btn || i18nWallet.disconnectBtn;
            i18nWallet.prefillHalf = t.wallet_prefill_half || i18nWallet.prefillHalf;
        });

        function updateWalletUI(state) {
            var btn = document.getElementById('wallet-btn');
            var btnLabel = document.getElementById('wallet-btn-label');
            var prefillBar = document.getElementById('wallet-prefill-bar');
            var halfLabel = document.getElementById('wallet-prefill-half-label');

            if (state && state.connected && state.address) {
                _walletBalance = state.balance ? parseFloat(state.balance) : null;

                if (btnLabel) {
                    var short = WalletConnect.shortenAddress(state.address);
                    btnLabel.textContent = state.balance != null ? short + ' · ' + state.balance + ' TON' : short;
                }
                if (btn) btn.onclick = function() { WalletConnect.disconnect(); };

                if (prefillBar) {
                    prefillBar.classList.remove('is-hidden');
                    if (halfLabel && _walletBalance != null) {
                        halfLabel.textContent = i18nWallet.prefillHalf.replace('{bal}', (_walletBalance / 2).toFixed(2));
                    }
                }
            } else {
                if (btnLabel) btnLabel.textContent = i18nWallet.connectBtn;
                if (btn) btn.onclick = function() { WalletConnect.connect(); };
                _walletBalance = null;
                if (prefillBar) prefillBar.classList.add('is-hidden');
            }
        }

        function walletPrefillHalf() {
            if (_walletBalance == null) return;
            prefillIframe((_walletBalance / 2).toFixed(2));
        }

        function walletPrefillMax() {
            if (_walletBalance == null) return;
            prefillIframe(_walletBalance.toFixed(2));
        }

        function prefillIframe(amount) {
            if (typeof window.openExchangeWidget === 'function') {
                window.openExchangeWidget();
            }

            setTimeout(function() {
                var iframe = document.getElementById('iframe-widget');
                if (iframe && iframe.contentWindow) {
                    iframe.contentWindow.postMessage({ type: 'set-amount', amount: amount }, '*');
                }
            }, 0);
        }

        document.addEventListener('DOMContentLoaded', function() {
            WalletConnect.onChange(updateWalletUI);
            WalletConnect.init('tonconnect-manifest.json', {
                sdkUrl: 'assets/js/vendor/tonconnect-ui.min.js',
                lazy: true
            });
        });
        {% endif %}
    </script>
