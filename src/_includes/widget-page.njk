<!doctype html>
<html lang="en">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport"
        content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    {% if activePage == 'bridge' %}<title>{{ t.title_bridge }}</title>{% else %}<title>{{ t.title_exchange }}</title>{% endif %}
    <meta name="description" content="TON Bridge HTML Mobile Template">
    <meta name="keywords"
        content="bootstrap, wallet, banking, fintech mobile template, cordova, phonegap, mobile, html, responsive" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="manifest" href="__manifest.json">
</head>

<body>
    <div id="viewport"></div>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script>
        Telegram.WebApp.ready();
        Telegram.WebApp.expand();

        Telegram.WebApp.onEvent('themeChanged', function() {
            document.documentElement.className = Telegram.WebApp.colorScheme;
        });

        Telegram.WebApp.setHeaderColor('secondary_bg_color');

        (function() {
            var tg = Telegram.WebApp;
            var mainButton = tg.MainButton;
            var buttonText = '{% if activePage == "bridge" %}{{ t.main_button_bridge }}{% else %}{{ t.main_button_exchange }}{% endif %}';
            mainButton.setText(buttonText);

            window.addEventListener('message', function(event) {
                if (!event.data || typeof event.data !== 'object') return;
                var type = event.data.type;
                if (type === 'deeplink' || type === 'change-now-widget-step') {
                    var step = event.data.step || event.data.value || '';
                    if (step === 'initial' || step === 'success' || step === 'finish') {
                        mainButton.hide();
                    } else {
                        mainButton.show();
                    }
                }
            });

            mainButton.onClick(function() {
                var iframe = document.getElementById('iframe-widget');
                if (iframe && iframe.contentWindow) {
                    iframe.contentWindow.postMessage({ type: 'submit' }, '*');
                }
            });

            window.addEventListener('beforeunload', function() {
                mainButton.hide();
            });
        })();
    </script>
    <!-- loader -->
    <div id="loader">
        <img src="assets/img/loading-icon.png" alt="icon" class="loading-icon">
    </div>
    <!-- * loader -->

    <!-- App Header -->
    <div class="appHeader bg-primary text-light">
        <div class="left">
            <a href="#" class="headerButton" data-bs-toggle="modal" data-bs-target="#sidebarPanel">
                <ion-icon name="menu-outline"></ion-icon>
            </a>
        </div>
        <div class="pageTitle">
            <img src="https://tonbankcard.com/images/logo-full-white.png" alt="logo" class="logo">
        </div>
    </div>
    <!-- * App Header -->

    <!-- App Capsule -->
    <div id="appCapsule">

		<!-- App {{ sectionLabel }} -->
<!-- {% if activePage == 'bridge' %}{{ t.bridge_img_comment }}{% else %}{{ t.exchange_img_comment }}{% endif %} -->
            <div class="text-center mb-4">
                <img src="{{ imgSrc }}" alt="Intro Image" style="width: {{ imgW }}; height: {{ imgH }};">
            </div>
<!-- {% if activePage == 'bridge' %}{{ t.bridge_section_comment }}{% else %}{{ t.exchange_section_comment }}{% endif %} -->

                    <h3>&nbsp;{% if activePage == 'bridge' %}{{ t.bridge_heading }}{% else %}{{ t.exchange_heading }}{% endif %}</h3>
                    <p>
                        &nbsp;{% if activePage == 'bridge' %}{{ t.bridge_intro_line1 }}{% else %}{{ t.exchange_intro_line1 }}{% endif %}
                        {% if activePage == 'bridge' %}{{ t.bridge_intro_line2 }}{% else %}{{ t.exchange_intro_line2 }}{% endif %}
                    </p>
                    <ul class="list-unstyled">
                        <li>&nbsp;{% if activePage == 'bridge' %}{{ t.bridge_point1 }}{% else %}{{ t.exchange_point1 }}{% endif %}</li>
                        <li>&nbsp;{% if activePage == 'bridge' %}{{ t.bridge_point2 }}{% else %}{{ t.exchange_point2 }}{% endif %}</li>
                        <li>&nbsp;{% if activePage == 'bridge' %}{{ t.bridge_point3 }}{% else %}{{ t.exchange_point3 }}{% endif %}</li>
                    </ul>
	    </br><iframe id='iframe-widget' src='https://changenow.io/embeds/exchange-widget/v2/widget.html?FAQ=true&amount={{ iframeAmount }}&amountFiat&backgroundColor=f6fafd&darkMode=false&from={{ iframeFrom }}&horizontal=false&isFiat=false&lang={{ t.widget_lang }}&link_id=3cc0024a18fd9d&locales=true&logo=false&primaryColor=1bb2da&to={{ iframeTo }}&toTheMoon=false' style="height: 450px; width: 100%; border: none"></iframe>
		<script defer type='text/javascript' src='https://changenow.io/embeds/exchange-widget/v2/stepper-connector.js'></script>
        <!-- * App {{ sectionLabel }} -->
<center><a href="https://ton.app/bridges/cede.store?id=2722" target="_blank"><img src="https://ton.app/a2/badge/topapp?appId=2722" alt="Cede.store — #undefined Bridge in Ton App" loading="lazy"/></a></center></br></br>
<center>
<table>
<tr><td>
                        <div class="col-lg-4">
                            <div class="feature animated" data-animate="fadeInUp" data-delay=".7">
                                <div class="feature-icon dot">
                                    <center><ion-icon name="information-outline" style="font-size: 64px;"></center>
                                </div>
                            </div>
                        </div></td><td><a href="{% if activePage == 'bridge' %}{{ t.bridge_instruction_link }}{% else %}{{ t.exchange_instruction_link }}{% endif %}" class="btn btn-primary btn-lg">{% if activePage == 'bridge' %}{{ t.bridge_instruction_btn }}{% else %}{{ t.exchange_instruction_btn }}{% endif %}</a></td></tr>
</table>

</center></br></br>
    </div>
    <!-- * App Capsule -->

    <!-- App Bottom Menu -->
    <div class="appBottomMenu">
        <a href="index{{ t.suffix }}.html" class="item{% if activePage == 'bridge' %} active{% endif %}">
            <div class="col">
                <ion-icon name="sync"></ion-icon>
                <strong>{{ t.nav_bridge }}</strong>
            </div>
        </a>
        <a href="index2{{ t.suffix }}.html" class="item{% if activePage == 'exchange' %} active{% endif %}">
            <div class="col">
                <ion-icon name="swap-horizontal-outline"></ion-icon>
                <strong>{{ t.nav_exchange }}</strong>
            </div>
        </a>
        <a href="index3{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="cash-outline"></ion-icon>
                <strong>{{ t.nav_otc }}</strong>
            </div>
        </a>
        <!-- <a href="index4{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="stats-chart"></ion-icon>
                <strong>{{ t.nav_statistics }}</strong>
            </div>
        </a> -->
        <a href="app-settings{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="settings-outline"></ion-icon>
                <strong>{{ t.nav_settings }}</strong>
            </div>
        </a>
    </div>
    <!-- * App Bottom Menu -->

    <!-- App Sidebar -->
    <div class="modal fade panelbox panelbox-left" id="sidebarPanel" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-body p-0">

<!-- menu -->
<div class="listview-title mt-1">{{ t.menu_title }}</div>
<ul class="listview flush transparent no-line image-listview">
    <li>
        <a href="app-settings{{ t.suffix }}.html" class="item">
            <div class="icon-box bg-primary">
                <ion-icon name="settings-outline"></ion-icon>
            </div>
            <div class="in">
                {{ t.menu_settings }}
            </div>
        </a>
    </li>
    <li>
        <a href="javascript:Telegram.WebApp.openTelegramLink('https://t.me/tonbankcard_bot');" class="item">
            <div class="icon-box bg-primary">
                <ion-icon name="chatbubble-outline"></ion-icon>
            </div>
            <div class="in">
                {{ t.menu_support }}
            </div>
        </a>
    </li>
</ul>

                     <!-- community section -->
<div class="listview-title mt-1">{{ t.community_title }}</div>
<ul class="listview flush transparent no-line image-listview">
    <li>
        <a href="javascript:Telegram.WebApp.openTelegramLink('{{ t.community_group_link }}');" class="item">
            <div class="icon-box bg-secondary">
                <ion-icon name="people-circle-outline"></ion-icon>
            </div>
            <div class="in">
                {{ t.community_group }}
            </div>
        </a>
    </li>
    <li>
        <a href="javascript:Telegram.WebApp.openTelegramLink('{{ t.community_chat_link }}');" class="item">
            <div class="icon-box bg-secondary">
                <ion-icon name="chatbubbles-outline"></ion-icon>
            </div>
            <div class="in">
                {{ t.community_chat }}
            </div>
        </a>
    </li>
</ul>
                    <!-- * community section -->
                    <!-- * menu -->
                </div>
            </div>
        </div>
    </div>
    <!-- * App Sidebar -->

    <div id="cookiesbox" class="offcanvas offcanvas-bottom cookies-box" tabindex="-1" data-bs-scroll="true"
        data-bs-backdrop="false" role="dialog" aria-labelledby="cookiesboxTitle" aria-modal="true">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="cookiesboxTitle">{{ t.cookies_title }}</h5>
        </div>
        <div class="offcanvas-body">
            <div class="mb-2">
                {{ t.cookies_body }}
                <a href="{{ t.privacy_link }}" class="text-secondary"><u>{{ t.cookies_learn_more }}</u></a>
            </div>
            <ul class="listview image-listview text inset no-line mb-2">
                <li>
                    <div class="item">
                        <div class="in">
                            <div>
                                <strong>{{ t.cookies_necessary_label }}</strong>
                                <div class="text-muted" style="font-size:0.82em">{{ t.cookies_necessary_desc }}</div>
                            </div>
                            <div class="form-check form-switch ms-2">
                                <input class="form-check-input" type="checkbox" id="consentNecessary" checked disabled>
                                <label class="form-check-label" for="consentNecessary"></label>
                            </div>
                        </div>
                    </div>
                </li>
                <li>
                    <div class="item">
                        <div class="in">
                            <div>
                                <strong>{{ t.cookies_analytics_label }}</strong>
                                <div class="text-muted" style="font-size:0.82em">{{ t.cookies_analytics_desc }}</div>
                            </div>
                            <div class="form-check form-switch ms-2">
                                <input class="form-check-input consent-analytics-toggle" type="checkbox" id="consentAnalytics">
                                <label class="form-check-label" for="consentAnalytics"></label>
                            </div>
                        </div>
                    </div>
                </li>
                <li>
                    <div class="item">
                        <div class="in">
                            <div>
                                <strong>{{ t.cookies_marketing_label }}</strong>
                                <div class="text-muted" style="font-size:0.82em">{{ t.cookies_marketing_desc }}</div>
                            </div>
                            <div class="form-check form-switch ms-2">
                                <input class="form-check-input consent-marketing-toggle" type="checkbox" id="consentMarketing">
                                <label class="form-check-label" for="consentMarketing"></label>
                            </div>
                        </div>
                    </div>
                </li>
            </ul>
            <div class="buttons">
                <a href="#" class="btn btn-primary btn-block accept-cookies accept-all-cookies mb-1" data-bs-dismiss="offcanvas">{{ t.cookies_accept }}</a>
                <a href="#" class="btn btn-outline-primary btn-block accept-cookies accept-selected-cookies mb-1" data-bs-dismiss="offcanvas">{{ t.cookies_accept_selected }}</a>
                <a href="#" class="btn btn-link btn-block accept-cookies decline-optional-cookies" data-bs-dismiss="offcanvas">{{ t.cookies_decline }}</a>
            </div>
        </div>
