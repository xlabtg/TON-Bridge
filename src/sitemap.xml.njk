---
permalink: sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {%- set pages = [
    { loc: baseUrl + "/index.html",           alt: baseUrl + "/index-ru.html",           lang: "en", altLang: "ru" },
    { loc: baseUrl + "/index-ru.html",        alt: baseUrl + "/index.html",              lang: "ru", altLang: "en" },
    { loc: baseUrl + "/index2.html",          alt: baseUrl + "/index2-ru.html",          lang: "en", altLang: "ru" },
    { loc: baseUrl + "/index2-ru.html",       alt: baseUrl + "/index2.html",             lang: "ru", altLang: "en" },
    { loc: baseUrl + "/index3.html",          alt: baseUrl + "/index3-ru.html",          lang: "en", altLang: "ru" },
    { loc: baseUrl + "/index3-ru.html",       alt: baseUrl + "/index3.html",             lang: "ru", altLang: "en" },
    { loc: baseUrl + "/0.html",               alt: baseUrl + "/0-ru.html",               lang: "en", altLang: "ru" },
    { loc: baseUrl + "/0-ru.html",            alt: baseUrl + "/0.html",                  lang: "ru", altLang: "en" },
    { loc: baseUrl + "/1.html",               alt: baseUrl + "/1-ru.html",               lang: "en", altLang: "ru" },
    { loc: baseUrl + "/1-ru.html",            alt: baseUrl + "/1.html",                  lang: "ru", altLang: "en" },
    { loc: baseUrl + "/2.html",               alt: baseUrl + "/2-ru.html",               lang: "en", altLang: "ru" },
    { loc: baseUrl + "/2-ru.html",            alt: baseUrl + "/2.html",                  lang: "ru", altLang: "en" },
    { loc: baseUrl + "/app-settings.html",    alt: baseUrl + "/app-settings-ru.html",   lang: "en", altLang: "ru" },
    { loc: baseUrl + "/app-settings-ru.html", alt: baseUrl + "/app-settings.html",      lang: "ru", altLang: "en" }
  ] -%}
  {%- for p in pages %}
  <url>
    <loc>{{ p.loc }}</loc>
    <xhtml:link rel="alternate" hreflang="{{ p.lang }}" href="{{ p.loc }}"/>
    <xhtml:link rel="alternate" hreflang="{{ p.altLang }}" href="{{ p.alt }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ p.loc if p.lang == 'en' else p.alt }}"/>
    <changefreq>weekly</changefreq>
    <priority>{{ "1.0" if "index.html" == p.loc.split("/")[-1] else "0.8" }}</priority>
  </url>
  {%- endfor %}
</urlset>
