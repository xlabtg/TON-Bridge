    <script>
    (function() {
        var CACHE_KEY = 'affiliate_me_cache';
        var CACHE_TTL = 60000; // 60 seconds

        // Global stats chart (ApexCharts)
        var chartOptions = {
            chart: { type: 'bar', height: 240, toolbar: { show: false } },
            series: [
                {
                    name: '{{ t.affiliate_global_buy_label }}',
                    data: [0.443, 0.864, 2.375, 6.249, 0.282, 8.072]
                },
                {
                    name: '{{ t.affiliate_global_sell_label }}',
                    data: [9.904, 15.827, 0.195, 1.861, 0.702, 0.089]
                }
            ],
            xaxis: {
                categories: ['TON', 'USDTTON', 'SOL', 'BTC', 'ETH', 'USDTERC20'],
                labels: { style: { fontSize: '11px' } }
            },
            yaxis: {
                labels: {
                    formatter: function(val) { return val.toFixed(2); }
                }
            },
            title: {
                text: '{{ t.affiliate_global_chart_title }}',
                align: 'center',
                style: { fontSize: '13px' }
            },
            colors: ['#1bb2da', '#e17055'],
            plotOptions: { bar: { borderRadius: 3 } },
            legend: { position: 'top' },
            dataLabels: { enabled: false }
        };
        new ApexCharts(document.getElementById('volumeChart'), chartOptions).render();

        // Helper: truncate user ID for anonymisation (show first 3 + last 2 chars)
        function truncateUser(uid) {
            var s = String(uid);
            if (s.length <= 6) return s;
            return s.slice(0, 3) + '…' + s.slice(-2);
        }

        function formatDate(iso) {
            try {
                var d = new Date(iso);
                return d.toLocaleDateString();
            } catch(e) { return iso; }
        }

        function renderStats(data) {
            var tbc = (data.points_balance / 10).toFixed(2);
            var usd = (parseFloat(tbc) * 0.0003).toFixed(4);
            document.getElementById('stat-turnover').textContent = '$' + (data.lifetime_turnover_usd || 0).toFixed(2);
            document.getElementById('stat-points-earned').textContent = (data.lifetime_points_earned || 0).toLocaleString();
            document.getElementById('stat-points-balance').textContent = (data.points_balance || 0).toLocaleString();
            document.getElementById('stat-tbc').textContent = tbc + ' TBC';
            document.getElementById('stat-usd').textContent = '≈ $' + usd;
        }

        function renderSwaps(swaps) {
            var tbody = document.getElementById('swaps-body');
            tbody.innerHTML = '';
            if (!swaps || !swaps.length) {
                var tr = document.createElement('tr');
                tr.innerHTML = '<td colspan="4" class="text-center text-muted">—</td>';
                tbody.appendChild(tr);
                return;
            }
            swaps.forEach(function(s) {
                var tr = document.createElement('tr');
                tr.innerHTML =
                    '<td>' + formatDate(s.created_at) + '</td>' +
                    '<td>' + (s.from_currency || '?') + '→' + (s.to_currency || '?') + '</td>' +
                    '<td>$' + (s.turnover_usd || 0).toFixed(2) + '</td>' +
                    '<td>' + (s.points_awarded || 0) + '</td>';
                tbody.appendChild(tr);
            });
        }

        function renderReferrals(referrals) {
            var tbody = document.getElementById('referrals-body');
            tbody.innerHTML = '';
            if (!referrals || !referrals.length) {
                var tr = document.createElement('tr');
                tr.innerHTML = '<td colspan="4" class="text-center text-muted">—</td>';
                tbody.appendChild(tr);
                return;
            }
            referrals.forEach(function(r, i) {
                var tr = document.createElement('tr');
                tr.innerHTML =
                    '<td>' + (i + 1) + '</td>' +
                    '<td>' + truncateUser(r.user_id) + '</td>' +
                    '<td>$' + (r.turnover_usd || 0).toFixed(2) + '</td>' +
                    '<td>' + (r.referral_points || 0) + '</td>';
                tbody.appendChild(tr);
            });
        }

        function showSection(id) {
            ['affiliate-loading', 'affiliate-error', 'affiliate-unauthenticated', 'affiliate-data'].forEach(function(s) {
                document.getElementById(s).style.display = (s === id) ? '' : 'none';
            });
        }

        function loadFromApi() {
            fetch('/me/affiliate', { credentials: 'include' })
                .then(function(res) {
                    if (res.status === 401 || res.status === 403) {
                        showSection('affiliate-unauthenticated');
                        return null;
                    }
                    if (!res.ok) throw new Error('HTTP ' + res.status);
                    return res.json();
                })
                .then(function(data) {
                    if (!data) return;
                    var cached = { ts: Date.now(), data: data };
                    try {
                        if (Telegram.WebApp.CloudStorage) {
                            Telegram.WebApp.CloudStorage.setItem(CACHE_KEY, JSON.stringify(cached));
                        }
                    } catch(e) {}
                    renderStats(data);
                    renderSwaps(data.last_swaps);
                    renderReferrals(data.referral_leaderboard);
                    showSection('affiliate-data');
                })
                .catch(function() {
                    showSection('affiliate-error');
                });
        }

        function init() {
            // Try CloudStorage cache first
            try {
                if (Telegram.WebApp.CloudStorage) {
                    Telegram.WebApp.CloudStorage.getItem(CACHE_KEY, function(err, val) {
                        if (!err && val) {
                            try {
                                var cached = JSON.parse(val);
                                if (Date.now() - cached.ts < CACHE_TTL) {
                                    renderStats(cached.data);
                                    renderSwaps(cached.data.last_swaps);
                                    renderReferrals(cached.data.referral_leaderboard);
                                    showSection('affiliate-data');
                                    return;
                                }
                            } catch(e) {}
                        }
                        loadFromApi();
                    });
                    return;
                }
            } catch(e) {}
            loadFromApi();
        }

        init();
        wireBackButton();
    })();
    </script>

