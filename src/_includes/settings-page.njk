            </div>
        </a>
        <a href="referral{{ t.suffix }}.html" class="item" role="tab" aria-selected="false">
            <div class="col">
                <ion-icon name="star-outline" aria-hidden="true"></ion-icon>
                <strong data-i18n="nav_referral">{{ locales.en.nav_referral }}</strong>
            </div>
        </a>
        <a href="app-settings{{ t.suffix }}.html" class="item active" role="tab" aria-selected="true">
            <div class="col">
                <ion-icon name="settings-outline" aria-hidden="true"></ion-icon>
