<script defer src="https://telegram.org/js/telegram-web-app.js" integrity="sha384-1XuC9S4cgk6RH1oCsL2diDRwLiiivu/oZHNfxYUitEFuiKpP5ceNbzu220KKrcK+" crossorigin="anonymous"></script>
    <script defer src="assets/js/auth.js"></script>
    <script>
        // Wait for the deferred telegram-web-app.js to finish executing;
        // defer scripts run after parsing and before DOMContentLoaded.
        document.addEventListener('DOMContentLoaded', function() {
        Telegram.WebApp.ready();
        Telegram.WebApp.expand();

        Telegram.WebApp.onEvent('themeChanged', function() {
            document.documentElement.className = Telegram.WebApp.colorScheme;
        });

        Telegram.WebApp.setHeaderColor('secondary_bg_color');

        // Apply themeParams CSS variables on first load
        (function() {
            var localDarkMode = false;
            try {
                localDarkMode = localStorage.getItem('FinappDarkmode') === '1' || document.body.classList.contains('dark-mode');
            } catch (e) {
                localDarkMode = document.body.classList.contains('dark-mode');
            }
            if (localDarkMode && Telegram.WebApp.colorScheme !== 'dark') return;

            var params = Telegram.WebApp.themeParams || {};
            var root = document.documentElement;
            for (var key in params) {
                if (Object.prototype.hasOwnProperty.call(params, key)) {
                    root.style.setProperty('--tg-theme-' + key.replace(/_/g, '-'), params[key]);
                }
            }
        })();

        (function() {
            var tg = Telegram.WebApp;
            var mainButton = tg.MainButton;

            document.addEventListener('i18n:applied', function(e) {
                if (e.detail.t && e.detail.t.main_button_otc) {
                    mainButton.setText(e.detail.t.main_button_otc);
                }
            });

            window.addEventListener('message', function(event) {
                if (!event.data || typeof event.data !== 'object') return;
                var type = event.data.type;
                if (type === 'deeplink' || type === 'change-now-widget-step') {
                    var step = event.data.step || event.data.value || '';
                    if (step === 'initial' || step === 'success' || step === 'finish') {
                        mainButton.hide();
                        if (step === 'finish' || step === 'success') {
                            haptic.notification('success');
                        }
                    } else if (step === 'failed' || step === 'error' || step === 'refunded') {
                        haptic.notification('error');
                        mainButton.show();
                    } else {
                        mainButton.show();
                    }
                }
            });

            mainButton.onClick(function() {
                haptic.impact('medium');
                var iframe = document.getElementById('iframe-widget');
                if (!iframe && typeof window.openExchangeWidget === 'function') {
                    window.openExchangeWidget();
                    return;
                }
                function submitToIframe() {
                    if (iframe && iframe.contentWindow) {
                        iframe.contentWindow.postMessage({ type: 'submit' }, '*');
                    }
                }
                // A real USD oracle will be wired once #6.4 lands.
                var amount = parseFloat(window.__otcAmount);
                if (window.BiometricAuth) {
                    BiometricAuth.guardTrade(
                        amount,
                        window.i18n && i18n.t('biometric_reason', 'Confirm exchange'),
                        window.i18n && i18n.t('biometric_failure_toast', 'Biometric authentication failed. Trade cancelled.'),
                        submitToIframe,
                        null
                    );
                } else {
                    submitToIframe();
                }
            });

            window.addEventListener('beforeunload', function() {
                mainButton.hide();
            });
        })();
        });
    </script>
