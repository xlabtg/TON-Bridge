# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.

# JWT issued by @DataChief_bot for tganalytics.xyz.
# Rotate via the DataChief bot and update this value; the old token must be
# invalidated by the repo owner at tganalytics.xyz after rotation.
TG_ANALYTICS_TOKEN=your-tganalytics-jwt-here

# Analytics identifier registered in @DataChief_bot (usually the bot username).
TG_ANALYTICS_APP_NAME=your-analytics-app-name

# Yandex.Metrika counter ID (numeric).
# Obtain from metrika.yandex.ru → Settings → Counter ID.
YANDEX_METRIKA_ID=your-yandex-metrika-id-here

# ChangeNOW partner link_id used in exchange-widget iframe URLs.
# Obtain from your ChangeNOW partner account.
CHANGENOW_LINK_ID=your-changenow-link-id-here

# Telegram bot username used for deep links (without the leading @).
BOT_USERNAME=your-bot-username

# Optional deployment values written by the PHP/MySQL hosting installer.
BASE_URL=https://example.com/bridge
ADMIN_TELEGRAM_IDS=
SUPPORT_BOT_USERNAME=
TELEGRAM_MINI_APP_SHORT_NAME=app
TELEGRAM_BOT_TOKEN=
CHANGENOW_API_KEY=
WORKER_BASE_URL=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tonbridge
DB_USERNAME=tonbridge_user
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_TABLE_PREFIX=tonbridge_
