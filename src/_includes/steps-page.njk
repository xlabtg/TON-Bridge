<!doctype html>
<html lang="{{ t.lang_attr }}">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    <title data-i18n="{% if stepsType == 'bridge' %}title_intro_bridge_steps{% else %}title_intro_exchange_steps{% endif %}">{% if stepsType == 'bridge' %}{{ t.title_intro_bridge_steps }}{% else %}{{ t.title_intro_exchange_steps }}{% endif %}</title>
    {% if stepsType == 'bridge' %}
    {% set seoTitle = t.title_intro_bridge_steps %}
    {% set seoDesc = t.desc_intro_bridge_steps %}
    {% else %}
    {% set seoTitle = t.title_intro_exchange_steps %}
    {% set seoDesc = t.desc_intro_exchange_steps %}
    {% endif %}
    {% include "seo-head.njk" %}
    <meta name="keywords" content="bootstrap, wallet, banking, fintech mobile template, cordova, phonegap, mobile, html, responsive" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    {% include "performance-head.njk" %}
    <link rel="manifest" href="__manifest.json">
    {# Enforced CSP (issue #117). 'unsafe-inline' is still required while the page
       shells contain inline <script> blocks templated with Nunjucks variables and
       inline event handlers (onclick/onload); migrating those to external files is
       tracked in #185. The policy is also delivered as an HTTP response header in
       .htaccess (issue #185) so that `frame-ancestors` (clickjacking) takes effect
       — it is silently ignored inside <meta>. `report-uri`/`report-to`/`sandbox`
       likewise need a header and stay omitted until a report collector exists. #}
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://telegram.org https://tganalytics.xyz https://changenow.io https://mc.yandex.ru; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https://changenow.io; connect-src 'self' https://*.changenow.io https://api.telegram.org https://tganalytics.xyz https://*.workers.dev https://mc.yandex.ru">
</head>

<body>
    <div id="offline-indicator" data-i18n="offline_indicator">You are offline</div>
    <div id="viewport"></div>
<script src="https://telegram.org/js/telegram-web-app.js" integrity="sha384-1XuC9S4cgk6RH1oCsL2diDRwLiiivu/oZHNfxYUitEFuiKpP5ceNbzu220KKrcK+" crossorigin="anonymous"></script>
    <script src="assets/js/auth.js"></script>
    <script>
        Telegram.WebApp.ready();
        Telegram.WebApp.expand();

        Telegram.WebApp.onEvent('themeChanged', function() {
            document.documentElement.className = Telegram.WebApp.colorScheme;
        });

        Telegram.WebApp.setHeaderColor('secondary_bg_color');
    </script>
    <!-- loader -->
    <div id="loader" aria-hidden="true">
        <img src="assets/img/loading-icon.webp" alt="" role="presentation" class="loading-icon">
    </div>
    <!-- * loader -->

    <!-- App Header -->
    <div class="appHeader bg-primary text-light">
        <div class="left">
        </div>
        <div class="pageTitle">
            <img src="https://tonbankcard.com/images/logo-full-white.png" alt="{{ t.logo_alt }}" data-i18n-attr="alt:logo_alt" class="logo">
        </div>
    </div>
    <!-- * App Header -->

    <!-- App Capsule -->
    <div id="appCapsule">
        <!-- Welcome message and steps -->
        <section id="welcomeSection" class="section mt-5">
            <div class="container">
                <!-- Welcome message -->
                <div class="section-head text-center">
                    <h2 class="title title-lg" data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_title{% else %}intro_exchange_steps_title{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_title }}{% else %}{{ t.intro_exchange_steps_title }}{% endif %}</h2>
                    <p data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_subtitle{% else %}intro_exchange_steps_subtitle{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_subtitle }}{% else %}{{ t.intro_exchange_steps_subtitle }}{% endif %}</p>
                </div>

                <!-- 3 steps -->
                <div id="how_it_works" class="section-head">
                    <h2 class="title title-lg animated" data-animate="fadeInUp" data-delay=".6" data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_heading{% else %}intro_exchange_steps_heading{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_heading }}{% else %}{{ t.intro_exchange_steps_heading }}{% endif %}</h2>
                </div>
                <div class="nk-block nk-block-features mgb-m30">
                    <p data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_lead{% else %}intro_exchange_steps_lead{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_lead }}{% else %}{{ t.intro_exchange_steps_lead }}{% endif %}</p>
                    <div class="row">
                        <div class="col-lg-4">
                            <div class="feature animated" data-animate="fadeInUp" data-delay=".7">
                                <div class="feature-icon dot text-center">
                                    <ion-icon name="wallet-outline" class="feature-icon-lg"></ion-icon>
                                </div>
                                <div class="feature-text">
                                    <h3 class="title title-lg" data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_s1_title{% else %}intro_exchange_steps_s1_title{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_s1_title }}{% else %}{{ t.intro_exchange_steps_s1_title }}{% endif %}</h3>
                                    <p data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_s1_desc{% else %}intro_exchange_steps_s1_desc{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_s1_desc }}{% else %}{{ t.intro_exchange_steps_s1_desc }}{% endif %}</p>
                                </div>
                            </div>
                        </div>
                       <div class="col-lg-4">
    <div class="feature animated" data-animate="fadeInUp" data-delay=".8">
        <div class="feature-icon dot text-center">
            {% if stepsType == 'bridge' %}<img src="https://tonbankcard.com/bridge/TMA2/assets/img/ton-logo.png" alt="TON Logo" class="feature-img-lg mx-auto">{% else %}<ion-icon name="code-download" class="feature-icon-lg"></ion-icon>{% endif %}
        </div>
        <div class="feature-text">
            <h3 class="title title-lg" data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_s2_title{% else %}intro_exchange_steps_s2_title{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_s2_title }}{% else %}{{ t.intro_exchange_steps_s2_title }}{% endif %}</h3>
            <p data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_s2_desc{% else %}intro_exchange_steps_s2_desc{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_s2_desc }}{% else %}{{ t.intro_exchange_steps_s2_desc }}{% endif %}</p>
        </div>
    </div>
</div>
                        <div class="col-lg-4">
                            <div class="feature animated" data-animate="fadeInUp" data-delay=".9">
                                <div class="feature-icon dot text-center">
                                    <ion-icon name="checkmark-done-outline" class="feature-icon-lg"></ion-icon>
                                </div>
                                <div class="feature-text">
                                    <h3 class="title title-lg" data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_s3_title{% else %}intro_exchange_steps_s3_title{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_s3_title }}{% else %}{{ t.intro_exchange_steps_s3_title }}{% endif %}</h3>
                                    <p data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_s3_desc{% else %}intro_exchange_steps_s3_desc{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_s3_desc }}{% else %}{{ t.intro_exchange_steps_s3_desc }}{% endif %}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- "START" button -->
                <div class="text-center mt-4">
                    <a href="{% if stepsType == 'bridge' %}index.html{% else %}index2.html{% endif %}" class="btn btn-primary btn-lg" data-i18n="{% if stepsType == 'bridge' %}intro_bridge_steps_btn{% else %}intro_exchange_steps_btn{% endif %}">{% if stepsType == 'bridge' %}{{ t.intro_bridge_steps_btn }}{% else %}{{ t.intro_exchange_steps_btn }}{% endif %}</a>
                </div>
            </div>
        </section>
    </div>

    <!-- Bootstrap -->
    <script src="assets/js/lib/bootstrap.bundle.min.js"></script>
    <!-- Ionicons (self-hosted sprite) -->
    <script src="assets/js/ion-icon.js" defer></script>
    <!-- i18n inline data + loader -->
    <script src="assets/js/prefs.js"></script>
    {% i18nDataScript %}
    <script src="assets/js/i18n.js"></script>
    <!-- Base Js File -->
    <script src="assets/js/base.js"></script>
    <!-- Sentry error reporting -->
    <script src="assets/js/sentry.js"></script>
    <!-- UTM attribution from directory listings -->
    <script src="assets/js/utm.js"></script>
    <!-- Offline Indicator -->
    <script src="assets/js/offline.js"></script>
    <!-- Telegram BackButton -->
    <script src="assets/js/back-button.js"></script>
    <script>
        wireBackButton();
        i18n.init();
    </script>

</body>

</html>
