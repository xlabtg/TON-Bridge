    <!-- loader -->
    <div id="loader">
        <img src="assets/img/loading-icon.png" alt="icon" class="loading-icon">
    </div>
    <!-- * loader -->

    <!-- App Header -->
    <div class="appHeader">
        <div class="left"></div>
        <div class="pageTitle">{{ t.redeem_title_label }}</div>
    </div>
    <!-- * App Header -->

    <!-- App Capsule -->
    <div id="appCapsule">

        <!-- Balance Card -->
        <div class="redeem-balance-card" id="balanceCard">
            <div class="points-value" id="balancePoints">—</div>
            <div class="points-label">{{ t.redeem_balance_points }}</div>
            <div class="equiv-row">
                <span id="balanceTbc">— {{ t.redeem_balance_tbc }}</span>
                &nbsp;·&nbsp;
                <span id="balanceUsd">— {{ t.redeem_balance_usd }}</span>
            </div>
        </div>

        <!-- No-balance message (hidden by default) -->
        <div id="noBalanceMsg" class="section mt-2 mb-2" style="display:none;">
            <div class="card">
                <div class="card-body text-center text-secondary">
                    {{ t.redeem_no_balance }}
                </div>
            </div>
        </div>

        <!-- Wallet missing notice (hidden by default) -->
        <div id="walletMissingMsg" class="section mt-1 mb-1" style="display:none;">
            <div class="card border-warning">
                <div class="card-body text-center" style="font-size:0.85rem;">
                    {{ t.redeem_wallet_missing }}
                </div>
            </div>
        </div>

        <!-- Slider Section -->
        <div id="redeemForm" class="redeem-slider-section" style="display:none;">
            <div class="listview-title mt-1">{{ t.redeem_slider_section }}</div>
            <div class="card">
                <div class="card-body">
                    <input type="range" id="redeemSlider"
                        min="100" max="100" step="10" value="100">
                    <div class="redeem-equiv-row">
                        <span>{{ t.redeem_slider_points_label }}: <strong id="sliderPoints">100</strong></span>
                        <span>{{ t.redeem_slider_tbc_label }}: <strong id="sliderTbc">10</strong></span>
                        <span>{{ t.redeem_slider_usd_label }}: <strong id="sliderUsd">$0.003</strong></span>
                    </div>
                    <div class="redeem-min-note">{{ t.redeem_min_note }}</div>
                </div>
            </div>
        </div>

        <!-- Redemption History -->
        <div id="historySection" style="display:none;">
            <div class="listview-title mt-1">{{ t.redeem_history_section }}</div>
            <ul class="listview image-listview text inset" id="historyList">
                <!-- filled by JS -->
            </ul>
            <div id="historyEmpty" class="section" style="display:none;">
                <div class="card">
                    <div class="card-body text-center text-secondary">
                        {{ t.redeem_history_empty }}
                    </div>
                </div>
            </div>
        </div>

    </div>
    <!-- * App Capsule -->

    <!-- App Bottom Menu -->
    <div class="appBottomMenu">
        <a href="index{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="sync"></ion-icon>
                <strong>{{ t.nav_bridge }}</strong>
            </div>
        </a>
        <a href="index2{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="swap-horizontal-outline"></ion-icon>
                <strong>{{ t.nav_exchange }}</strong>
            </div>
        </a>
        <a href="index3{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="cash-outline"></ion-icon>
                <strong>{{ t.nav_otc }}</strong>
            </div>
        </a>
        <a href="redeem{{ t.suffix }}.html" class="item active">
            <div class="col">
                <ion-icon name="gift-outline"></ion-icon>
                <strong>{{ t.nav_redeem }}</strong>
            </div>
        </a>
        <a href="app-settings{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="settings-outline"></ion-icon>
                <strong>{{ t.nav_settings }}</strong>
            </div>
        </a>
    </div>
    <!-- * App Bottom Menu -->

    <!-- Toast -->
    <div class="toast-msg" id="toastMsg"></div>

    <!-- ========= JS Files =========  -->
    <!-- Bootstrap -->
    <script src="assets/js/lib/bootstrap.bundle.min.js"></script>
    <!-- Ionicons -->
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
    <!-- Splide -->
    <script src="assets/js/plugins/splide/splide.min.js"></script>
    <!-- Base Js File -->
    <script src="assets/js/base.js"></script>
    <!-- Telegram BackButton -->
    <script src="assets/js/back-button.js"></script>
    <script>wireBackButton();</script>

    <script>
    (function () {
        var WORKER_BASE = 'https://ton-bridge-worker.tonbankcard.workers.dev';
        var TBC_PER_POINT = 0.1;   // 10 points = 1 TBC  =>  1 point = 0.1 TBC
        var USD_PER_TBC   = 0.0003;
        var MIN_POINTS    = 100;
        var STEP          = 10;

        var i18n = {
            balancePoints:   '{{ t.redeem_balance_points }}',
            balanceTbc:      '{{ t.redeem_balance_tbc }}',
            balanceUsd:      '{{ t.redeem_balance_usd }}',
            confirmMsg:      '{{ t.redeem_confirm_msg }}',
            success:         '{{ t.redeem_success }}',
            queued:          '{{ t.redeem_queued }}',
            errorMin:        '{{ t.redeem_error_min }}',
            errorBalance:    '{{ t.redeem_error_balance }}',
            errorInflight:   '{{ t.redeem_error_inflight }}',
            errorRatelimit:  '{{ t.redeem_error_ratelimit }}',
            errorServer:     '{{ t.redeem_error_server }}',
            statusRequested: '{{ t.redeem_history_status_requested }}',
            statusPaid:      '{{ t.redeem_history_status_paid }}',
            statusFailed:    '{{ t.redeem_history_status_failed }}',
            statusQueued:    '{{ t.redeem_history_status_queued }}',
            redeemButton:    '{{ t.redeem_button }}'
        };

        function pts2tbc(pts) { return Math.floor(pts / 10); }
        function pts2usd(pts) { return (pts2tbc(pts) * USD_PER_TBC).toFixed(3); }

        function showToast(msg, type) {
            var el = document.getElementById('toastMsg');
            el.textContent = msg;
            el.className = 'toast-msg ' + (type || '');
            el.style.display = 'block';
            setTimeout(function () { el.style.display = 'none'; }, 3500);
        }

        function statusLabel(status) {
            var map = {
                requested: i18n.statusRequested,
                paid:      i18n.statusPaid,
                failed:    i18n.statusFailed,
                queued:    i18n.statusQueued
            };
            return map[status] || status;
        }

        function statusClass(status) {
            var map = {
                requested: 'status-requested',
                paid:      'status-paid',
                failed:    'status-failed',
                queued:    'status-queued'
            };
            return map[status] || '';
        }

        function renderHistory(items) {
            var section = document.getElementById('historySection');
            var list    = document.getElementById('historyList');
            var empty   = document.getElementById('historyEmpty');
            section.style.display = 'block';
            list.innerHTML = '';
            if (!items || items.length === 0) {
                empty.style.display = 'block';
                return;
            }
            empty.style.display = 'none';
            items.forEach(function (r) {
                var date = r.created_at ? new Date(r.created_at).toLocaleDateString() : '';
                var li = document.createElement('li');
                li.innerHTML = '<div class="item">' +
                    '<div class="in redeem-history-item">' +
                        '<div>' +
                            '<strong>' + r.tbc_amount + ' TBC</strong>' +
                            '<div class="text-muted" style="font-size:0.8rem;">' +
                                r.points_spent + ' pts · ' + date +
                            '</div>' +
                        '</div>' +
                        '<span class="status-badge ' + statusClass(r.status) + '">' +
                            statusLabel(r.status) +
                        '</span>' +
                    '</div>' +
                '</div>';
                list.appendChild(li);
            });
        }

        function initSlider(balance) {
            var slider     = document.getElementById('redeemSlider');
            var sliderPts  = document.getElementById('sliderPoints');
            var sliderTbc  = document.getElementById('sliderTbc');
            var sliderUsd  = document.getElementById('sliderUsd');
            var form       = document.getElementById('redeemForm');

            // Snap balance down to the nearest multiple of STEP
            var maxPts = Math.floor(balance / STEP) * STEP;
            if (maxPts < MIN_POINTS) { return; }

            slider.min   = MIN_POINTS;
            slider.max   = maxPts;
            slider.step  = STEP;
            slider.value = MIN_POINTS;
            form.style.display = 'block';

            function updateDisplay() {
                var pts = parseInt(slider.value, 10);
                sliderPts.textContent = pts;
                sliderTbc.textContent = pts2tbc(pts);
                sliderUsd.textContent = '$' + pts2usd(pts);
            }
            updateDisplay();
            slider.addEventListener('input', updateDisplay);

            // Wire MainButton
            var tg = window.Telegram && window.Telegram.WebApp;
            if (tg && tg.MainButton) {
                tg.MainButton.setText(i18n.redeemButton);
                tg.MainButton.show();
                tg.MainButton.onClick(function () {
                    var pts = parseInt(slider.value, 10);
                    var tbc = pts2tbc(pts);
                    var usd = pts2usd(pts);
                    var msg = i18n.confirmMsg
                        .replace('{points}', pts)
                        .replace('{tbc}', tbc)
                        .replace('{usd}', usd);

                    if (tg.showConfirm) {
                        tg.showConfirm(msg, function (confirmed) {
                            if (confirmed) { submitRedeem(pts); }
                        });
                    } else {
                        if (window.confirm(msg)) { submitRedeem(pts); }
                    }
                });
            }
        }

        function submitRedeem(points) {
            var tg = window.Telegram && window.Telegram.WebApp;
            var initData = (tg && tg.initData) || '';

            if (tg && tg.MainButton) { tg.MainButton.disable && tg.MainButton.disable(); }

            fetch(WORKER_BASE + '/api/redeem', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ points_spent: points, initData: initData })
            })
            .then(function (res) { return res.json().then(function (body) { return { status: res.status, body: body }; }); })
            .then(function (r) {
                if (r.status === 200 || r.status === 201) {
                    var tbc = pts2tbc(points);
                    var msg = r.body.queued
                        ? i18n.queued
                        : i18n.success.replace('{tbc}', tbc);
                    showToast(msg, 'success');
                    loadData();
                } else {
                    var code = r.body && r.body.error;
                    var errMap = {
                        min_points:   i18n.errorMin,
                        low_balance:  i18n.errorBalance,
                        in_flight:    i18n.errorInflight,
                        rate_limit:   i18n.errorRatelimit
                    };
                    showToast(errMap[code] || i18n.errorServer, 'error');
                }
            })
            .catch(function () { showToast(i18n.errorServer, 'error'); })
            .finally(function () {
                if (tg && tg.MainButton) { tg.MainButton.enable && tg.MainButton.enable(); }
            });
        }

        function loadData() {
            var tg = window.Telegram && window.Telegram.WebApp;
            var initData = (tg && tg.initData) || '';

            fetch(WORKER_BASE + '/api/balance?initData=' + encodeURIComponent(initData))
            .then(function (res) { return res.json(); })
            .then(function (data) {
                var balance = data.points || 0;
                var hasTon  = !!data.ton_address;

                document.getElementById('balancePoints').textContent = balance;
                document.getElementById('balanceTbc').textContent = pts2tbc(balance) + ' ' + i18n.balanceTbc;
                document.getElementById('balanceUsd').textContent = '$' + (pts2tbc(balance) * USD_PER_TBC).toFixed(3) + ' ' + i18n.balanceUsd;

                if (balance < MIN_POINTS) {
                    document.getElementById('noBalanceMsg').style.display = 'block';
                    document.getElementById('redeemForm').style.display   = 'none';
                } else {
                    document.getElementById('noBalanceMsg').style.display = 'none';
                    if (!hasTon) {
                        document.getElementById('walletMissingMsg').style.display = 'block';
                    }
                    initSlider(balance);
                }

                renderHistory(data.redemptions || []);
            })
            .catch(function () {
                // Fallback: show 0 balance with empty history
                document.getElementById('balancePoints').textContent = '0';
                document.getElementById('balanceTbc').textContent = '0 TBC';
                document.getElementById('balanceUsd').textContent = '$0.000 USD';
                document.getElementById('noBalanceMsg').style.display = 'block';
                renderHistory([]);
            });
        }

        document.addEventListener('DOMContentLoaded', loadData);
    })();
    </script>

