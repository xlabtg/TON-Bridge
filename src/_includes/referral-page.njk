{% set activePage = 'referral' %}
<!doctype html>
<html lang="{{ t.lang_attr }}">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport"
        content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    <title>{{ t.title_referral }}</title>
    {% set seoTitle = t.title_referral %}
    {% set seoDesc = t.desc_referral %}
    {% include "seo-head.njk" %}
    <meta name="keywords"
        content="ton bridge, referral, tbc token, crypto, exchange" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="manifest" href="__manifest.json">
    {# Enforced CSP (issue #117). 'unsafe-inline' is required while the page shells
       contain inline <script> blocks templated with Nunjucks variables and inline
       event handlers (onclick/onload). Migrating to nonces/hashes is filed as a
       follow-up. `report-uri`, `report-to`, `frame-ancestors`, and `sandbox` are
       intentionally omitted — they are silently ignored inside <meta> and need an
       HTTP response header to take effect. #}
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://telegram.org https://tganalytics.xyz https://changenow.io https://cdn.jsdelivr.net https://mc.yandex.ru; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https://changenow.io; connect-src 'self' https://*.changenow.io https://api.telegram.org https://tganalytics.xyz https://*.workers.dev https://mc.yandex.ru">
</head>

<body class="referral-page">
    <div id="viewport"></div>
    <script src="https://telegram.org/js/telegram-web-app.js" integrity="sha384-1XuC9S4cgk6RH1oCsL2diDRwLiiivu/oZHNfxYUitEFuiKpP5ceNbzu220KKrcK+" crossorigin="anonymous"></script>
    <script>
        Telegram.WebApp.ready();
        Telegram.WebApp.expand();

        Telegram.WebApp.onEvent('themeChanged', function() {
            document.documentElement.className = Telegram.WebApp.colorScheme;
        });

        Telegram.WebApp.setHeaderColor('secondary_bg_color');
    </script>
    <script
        async
        src="https://tganalytics.xyz/index.js"
        integrity="sha384-njlroka3F7BclV9FXjiHDU9ZSrhSwNVRewye4d5rpWXYvery9PUnnhuAZAHfLyJ+"
        crossorigin="anonymous"
        onload="initAnalytics()"
        type="text/javascript"
    ></script>
    <script>
        function initAnalytics() {
          window.telegramAnalytics.init({
            token: {{ env.TG_ANALYTICS_TOKEN | jsString | safe }},
            appName: {{ env.TG_ANALYTICS_APP_NAME | jsString | safe }},
          });
        }
    </script>

    <!-- loader -->
    <div id="loader">
        <img src="assets/img/loading-icon.png" alt="icon" class="loading-icon">
    </div>
    <!-- * loader -->

    <!-- App Header -->
    <div class="appHeader referral-app-header">
        <div class="left">
            <a href="#" class="headerButton" data-bs-toggle="modal" data-bs-target="#sidebarPanel">
                <ion-icon name="menu-outline"></ion-icon>
            </a>
        </div>
        <div class="pageTitle">
            <img src="https://tonbankcard.com/images/logo-full-white.png" alt="logo" class="logo">
        </div>
    </div>
    <!-- * App Header -->

    <!-- App Capsule -->
    <div id="appCapsule">

        <div class="section mt-3 mb-2">
            <h2>{{ t.referral_heading }}</h2>
            <p class="text-muted">{{ t.referral_intro }}</p>
        </div>

        <!-- Referral link card -->
        <div class="section mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">{{ t.referral_link_label }}</h5>
                    <div class="input-group mb-2">
                        <input type="text" class="form-control" id="referral-link-input" readonly
                            value="{{ t.referral_loading }}" aria-label="{{ t.referral_link_label }}">
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn referral-primary-action flex-fill" id="copy-referral-btn"
                            aria-label="{{ t.referral_copy_btn }}">
                            <ion-icon name="copy-outline"></ion-icon>
                            {{ t.referral_copy_btn }}
                        </button>
                        <button class="btn referral-secondary-action flex-fill" id="share-referral-btn"
                            aria-label="{{ t.referral_share_btn }}">
                            <ion-icon name="share-social-outline"></ion-icon>
                            {{ t.referral_share_btn }}
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pending TBC rewards -->
        <div class="section mb-3" id="claim-section">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">{{ t.referral_claim_section }}</h5>
                    <div id="claim-loading" class="text-muted">{{ t.referral_loading }}</div>
                    <div id="claim-error" class="text-danger" style="display:none;">{{ t.referral_error }}</div>
                    <div id="claim-reward-disabled" class="text-warning" style="display:none;">{{ t.referral_rewards_disabled }}</div>
                    <div id="claim-no-pending" style="display:none;">
                        <p class="text-muted">{{ t.referral_no_pending }}</p>
                    </div>
                    <div id="claim-available" style="display:none;">
                        <p class="mb-1">{{ t.referral_claim_amount_label }}: <strong id="pending-tbc-count">—</strong> TBC</p>
                        <button class="btn referral-primary-action w-100" id="claim-reward-btn"
                            aria-label="{{ t.referral_claim_btn }}">
                            {{ t.referral_claim_btn }}
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- How it works -->
        <div class="section mb-3">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">{{ t.referral_how_title }}</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-1">1. {{ t.referral_how_step1 }}</li>
                        <li class="mb-1">2. {{ t.referral_how_step2 }}</li>
                        <li class="mb-1">3. {{ t.referral_how_step3 }}</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Program details -->
        <div class="section mb-3">
            <div class="card">
                <div class="card-body">
                    <ul class="listview flush transparent no-line">
                        <li>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">{{ t.referral_rate_label }}</span>
                                <strong>{{ t.referral_rate_value }}</strong>
                            </div>
                        </li>
                        <li class="mt-2">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">{{ t.referral_reward_unit_label }}</span>
                                <strong>{{ t.referral_reward_unit_value }}</strong>
                            </div>
                        </li>
                        <li class="mt-2">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">{{ t.referral_daily_cap_label }}</span>
                                <strong>{{ t.referral_daily_cap_value }}</strong>
                            </div>
                        </li>
                    </ul>
                    <p class="text-muted mt-2 mb-0" style="font-size:0.82em;">{{ t.referral_note }}</p>
                    <p class="text-muted mt-1 mb-0" style="font-size:0.82em;">{{ t.referral_tbc_note }}</p>
                </div>
            </div>
        </div>

    </div>
    <!-- * App Capsule -->

    <!-- App Bottom Menu -->
    {% include "bottom-nav.njk" %}
    <!-- * App Bottom Menu -->

    <!-- App Sidebar -->
    <div class="modal fade panelbox panelbox-left" id="sidebarPanel" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-body p-0">
                    <div class="listview-title mt-1">{{ t.menu_title }}</div>
                    <ul class="listview flush transparent no-line image-listview">
                        <li>
                            <a href="app-settings{{ t.suffix }}.html" class="item">
                                <div class="icon-box referral-sidebar-icon-primary">
                                    <ion-icon name="settings-outline"></ion-icon>
                                </div>
                                <div class="in">
                                    {{ t.menu_settings }}
                                </div>
                            </a>
                        </li>
                        <li>
                            <a href="https://t.me/tonbankcard_bot" class="item" id="support-link" target="_blank" rel="noopener noreferrer" data-telegram-link="support">
                                <div class="icon-box referral-sidebar-icon-primary">
                                    <ion-icon name="chatbubble-outline"></ion-icon>
                                </div>
                                <div class="in">
                                    {{ t.menu_support }}
                                </div>
                            </a>
                        </li>
                    </ul>
                    <div class="listview-title mt-1">{{ t.community_title }}</div>
                    <ul class="listview flush transparent no-line image-listview">
                        <li>
                            <a href="{{ t.community_group_link }}" class="item" id="community-group-link" target="_blank" rel="noopener noreferrer" data-telegram-link="community_group_link" data-i18n-attr="href:community_group_link">
                                <div class="icon-box referral-sidebar-icon-secondary">
                                    <ion-icon name="people-circle-outline"></ion-icon>
                                </div>
                                <div class="in">
                                    {{ t.community_group }}
                                </div>
                            </a>
                        </li>
                        <li>
                            <a href="{{ t.community_chat_link }}" class="item" id="community-chat-link" target="_blank" rel="noopener noreferrer" data-telegram-link="community_chat_link" data-i18n-attr="href:community_chat_link">
                                <div class="icon-box referral-sidebar-icon-secondary">
                                    <ion-icon name="chatbubbles-outline"></ion-icon>
                                </div>
                                <div class="in">
                                    {{ t.community_chat }}
                                </div>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <!-- * App Sidebar -->

    <!-- ========= JS Files =========  -->
    <!-- Bootstrap -->
    <script src="assets/js/lib/bootstrap.bundle.min.js"></script>
    <!-- Ionicons (self-hosted sprite) -->
    <script src="assets/js/ion-icon.js" defer></script>
    <!-- Splide -->
    <script src="assets/js/plugins/splide/splide.min.js"></script>
    <!-- Base Js File -->
    <script src="assets/js/base.js"></script>
    <!-- Sentry error reporting -->
    <script src="assets/js/sentry.js"></script>
    <!-- Referral Rewards -->
    <script src="assets/js/referral-rewards.js"></script>
    <script>
        ReferralRewards.init({
            lang: '{{ t.lang_attr }}',
            copied: '{{ t.referral_copied }}',
            redeemPath: 'redeem{{ t.suffix }}.html'
        });
    </script>

</body>

</html>
