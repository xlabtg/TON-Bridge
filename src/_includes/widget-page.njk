            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
        @media (prefers-reduced-motion: reduce) {
            .social-proof-pill .sp-dot { animation: none; }
        }
        .visually-hidden {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
