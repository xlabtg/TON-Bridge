<!doctype html>
<html lang="en">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport"
        content="width=device-width, initial-scale=1, minimum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    <title data-i18n="title_settings">{{ locales.en.title_settings }}</title>
    <meta name="description" content="TON Bridge HTML Mobile Template">
    <meta name="keywords" content="bootstrap, wallet, banking, fintech mobile template, cordova, phonegap, mobile, html, responsive" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    {% include "performance-head.njk" %}
    <link rel="manifest" href="__manifest.json">
    <meta http-equiv="Content-Security-Policy-Report-Only" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://telegram.org https://tganalytics.xyz https://changenow.io https://mc.yandex.ru; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https://changenow.io; connect-src 'self' https://*.changenow.io https://api.telegram.org https://tganalytics.xyz; report-uri /csp-report">
</head>

<body>
    <div id="offline-indicator">You are offline</div>

    <!-- loader -->
    <div id="loader" aria-hidden="true">
        <img src="assets/img/loading-icon.webp" alt="" role="presentation" class="loading-icon">
    </div>
    <!-- * loader -->

    <!-- App Header -->
    <div class="appHeader">
        <div class="left">
        </div>
        <div class="pageTitle" data-i18n="settings_title_label">
            {{ locales.en.settings_title_label }}
        </div>
    </div>
    <!-- * App Header -->

    <!-- App Capsule -->
    <div id="appCapsule">

    <div class="listview-title mt-1" data-i18n="settings_theme_section">{{ locales.en.settings_theme_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div id="darkmode-label" data-i18n="settings_dark_mode_label">
                        {{ locales.en.settings_dark_mode_label }}
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input dark-mode-switch" type="checkbox" id="darkmodeSwitch">
                        <label class="form-check-label" for="darkmodeSwitch" aria-hidden="true"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div class="listview-title mt-1" data-i18n="settings_lang_section">{{ locales.en.settings_lang_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div id="language-label" data-i18n="settings_lang_label">
                        {{ locales.en.settings_lang_label }}
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input language-switch" type="checkbox" id="languageSwitch">
                        <label class="form-check-label" for="languageSwitch" aria-hidden="true"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div class="listview-title mt-1" data-i18n="settings_leaderboard_section">{{ locales.en.settings_leaderboard_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div>
                        <div data-i18n="settings_leaderboard_label">{{ locales.en.settings_leaderboard_label }}</div>
                        <div class="text-muted" style="font-size:0.8em;" data-i18n="settings_leaderboard_hint">{{ locales.en.settings_leaderboard_hint }}</div>
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input leaderboard-optin-switch" type="checkbox" id="leaderboardOptinSwitch">
                        <label class="form-check-label" for="leaderboardOptinSwitch"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div class="listview-title mt-1" data-i18n="settings_notifications_section">{{ locales.en.settings_notifications_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div data-i18n="settings_notifications_label">
                        {{ locales.en.settings_notifications_label }}
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input" type="checkbox" id="notificationsSwitch" checked>
                        <label class="form-check-label" for="notificationsSwitch"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div class="listview-title mt-1" data-i18n="wallet_section">{{ locales.en.wallet_section }}</div>
    <ul class="listview image-listview text inset no-line" id="wallet-settings-list">
        <li id="wallet-settings-connect-row">
            <div class="item">
                <div class="in">
                    <div id="wallet-settings-status" data-i18n="wallet_connect_btn">{{ locales.en.wallet_connect_btn }}</div>
                    <button class="btn btn-primary btn-sm rounded" id="wallet-settings-btn" onclick="WalletConnect.connect()">
                        <ion-icon name="wallet-outline" style="font-size:16px;margin-right:4px;vertical-align:middle;"></ion-icon>
                        <span id="wallet-settings-btn-label" data-i18n="wallet_connect_btn">{{ locales.en.wallet_connect_btn }}</span>
                    </button>
                </div>
            </div>
        </li>
    </ul>

    <div class="listview-title mt-1" data-i18n="ab_section">{{ locales.en.ab_section }}</div>
    <ul class="listview image-listview text inset no-line" id="address-book-manage-list">
        <li><div class="item"><div class="in" data-i18n="ab_empty">{{ locales.en.ab_empty }}</div></div></li>
    </ul>

    <div class="listview-title mt-1" data-i18n="settings_security_section">{{ locales.en.settings_security_section }}</div>
    <ul class="listview image-listview text inset no-line" id="biometric-section">
        <li>
            <div class="item">
                <div class="in">
                    <div id="biometric-label-wrapper">
                        <span id="biometric-label" data-i18n="settings_biometric_label">{{ locales.en.settings_biometric_label }}</span>
                        <span id="biometric-unavailable-hint" class="text-muted" style="display:none; font-size:0.82em; margin-left:4px;" data-bs-toggle="tooltip" title="{{ locales.en.settings_biometric_unavailable_hint }}" data-i18n-attr="title:settings_biometric_unavailable_hint">(?)</span>
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input" type="checkbox" id="biometricSwitch" disabled>
                        <label class="form-check-label" for="biometricSwitch"></label>
                    </div>
                </div>
            </div>
        </li>
        <li id="biometric-threshold-row" style="display:none;">
            <div class="item">
                <div class="in">
                    <div data-i18n="settings_biometric_threshold_label">{{ locales.en.settings_biometric_threshold_label }}</div>
                    <div style="display:flex;align-items:center;gap:4px;">
                        <span>$</span>
                        <input type="number" id="biometricThreshold" min="1" step="1"
                            style="width:90px; border:1px solid #ccc; border-radius:6px; padding:2px 6px; text-align:right;"
                            value="1000">
                    </div>
                </div>
            </div>
        </li>
    </ul>

</div>
<script src="assets/js/biometric-manager.js"></script>
<script>
    (function () {
        var OPTIN_KEY = 'leaderboard_optin';
        var WORKER_URL = '{{ locales.en.settings_leaderboard_worker_url }}';
        var sw = document.getElementById('leaderboardOptinSwitch');

        if (!sw) return;

        var tg = window.Telegram && window.Telegram.WebApp;
        if (tg && tg.CloudStorage) {
            tg.CloudStorage.getItem(OPTIN_KEY, function(err, val) {
                if (!err && val === '1') {
                    sw.checked = true;
                }
            });
        }

        sw.addEventListener('change', function () {
            var optIn = sw.checked;
            var value = optIn ? '1' : '0';

            if (tg && tg.CloudStorage) {
                tg.CloudStorage.setItem(OPTIN_KEY, value);
            }

            if (WORKER_URL && tg && tg.initData && tg.initDataUnsafe && tg.initDataUnsafe.user) {
                fetch(WORKER_URL + '/optin', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': tg.initData,
                    },
                    body: JSON.stringify({
                        userId: String(tg.initDataUnsafe.user.id),
                        optIn: optIn,
                    }),
                }).catch(function() {});
            }
        });
    })();

    (function () {
        var STORAGE_KEY = 'pref:notificationsOptOut';
        var toggle = document.getElementById('notificationsSwitch');

        if (!toggle) return;

        function getPref(key) {
            if (window.prefs && window.prefs.get) return window.prefs.get(key);
            return Promise.resolve(localStorage.getItem(key));
        }

        function setPref(key, value) {
            if (window.prefs && window.prefs.set) return window.prefs.set(key, value);
            localStorage.setItem(key, value);
            return Promise.resolve();
        }

        getPref(STORAGE_KEY).then(function (value) {
            toggle.checked = value !== '1';
        });

        toggle.addEventListener('change', function () {
            setPref(STORAGE_KEY, this.checked ? '0' : '1');
        });
    })();

    (function () {
        var sw = document.getElementById('biometricSwitch');
        var thresholdRow = document.getElementById('biometric-threshold-row');
        var thresholdInput = document.getElementById('biometricThreshold');
        var unavailableHint = document.getElementById('biometric-unavailable-hint');

        function applyAvailability(available) {
            sw.disabled = !available;
            if (!available) {
                unavailableHint.style.display = 'inline';
            }
        }

        function applyEnabled(enabled) {
            sw.checked = enabled;
            thresholdRow.style.display = enabled ? '' : 'none';
        }

        BiometricAuth.init(function () {
            var available = BiometricAuth.isAvailable();
            applyAvailability(available);

            BiometricAuth.isEnabled(function (enabled) {
                applyEnabled(enabled);
            });

            BiometricAuth.getThreshold(function (threshold) {
                thresholdInput.value = threshold;
            });
        });

        sw.addEventListener('change', function () {
            BiometricAuth.setEnabled(this.checked);
            thresholdRow.style.display = this.checked ? '' : 'none';
        });

        thresholdInput.addEventListener('change', function () {
            var val = parseFloat(this.value);
            if (!isNaN(val) && val > 0) {
                BiometricAuth.setThreshold(val);
            }
        });
    })();
</script>
    <!-- * App Capsule -->


    <!-- App Bottom Menu -->
    <nav class="appBottomMenu" aria-label="{{ locales.en.nav_aria_label }}" data-i18n-attr="aria-label:nav_aria_label">
        <div role="tablist" aria-label="{{ locales.en.nav_aria_label }}" data-i18n-attr="aria-label:nav_aria_label">
        <a href="index.html" class="item" role="tab" aria-selected="false">
            <div class="col">
                <ion-icon name="sync" aria-hidden="true"></ion-icon>
                <strong data-i18n="nav_bridge">{{ locales.en.nav_bridge }}</strong>
            </div>
        </a>
        <a href="index2.html" class="item" role="tab" aria-selected="false">
            <div class="col">
                <ion-icon name="swap-horizontal-outline" aria-hidden="true"></ion-icon>
                <strong data-i18n="nav_exchange">{{ locales.en.nav_exchange }}</strong>
            </div>
        </a>
        <a href="index3.html" class="item" role="tab" aria-selected="false">
            <div class="col">
                <ion-icon name="cash-outline" aria-hidden="true"></ion-icon>
                <strong data-i18n="nav_otc">{{ locales.en.nav_otc }}</strong>
            </div>
        </a>
        <a href="orders.html" class="item" role="tab" aria-selected="false">
