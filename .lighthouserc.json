{
  "ci": {
    "collect": {
      "chromePath": "/usr/bin/google-chrome-stable",
      "puppeteerScript": "lhci/block-third-party.cjs",
      "puppeteerLaunchOptions": {
        "args": ["--no-sandbox", "--disable-dev-shm-usage"]
      },
      "staticDistDir": "dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/index2.html",
        "http://localhost/index3.html"
      ],
      "settings": {
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4,
          "requestLatencyMs": 562.5,
          "downloadThroughputKbps": 1474.56,
          "uploadThroughputKbps": 675
        },
        "screenEmulation": {
          "mobile": true,
          "width": 360,
          "height": 640,
          "deviceScaleFactor": 2.625,
          "disabled": false
        },
        "formFactor": "mobile",
        "emulatedUserAgent": "Mozilla/5.0 (Linux; Android 7.0; Moto G (4)) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/98.0.4695.0 Mobile Safari/537.36 Chrome-Lighthouse"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "aggregationMethod": "pessimistic",
      "assertions": {
        "largest-contentful-paint": ["error", { "maxNumericValue": 2750 }],
        "total-blocking-time": ["error", { "maxNumericValue": 300 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.90 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 204800 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 30720 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "first-contentful-paint": "off",
        "speed-index": "off",
        "interactive": "off",
        "uses-http2": "off",
        "uses-long-cache-ttl": "off",
        "canonical": "off",
        "maskable-icon": "off",
        "aria-dialog-name": "off",
        "color-contrast": "off",
        "errors-in-console": "off",
        "forced-reflow-insight": "off",
        "heading-order": "off",
        "image-aspect-ratio": "off",
        "image-delivery-insight": "off",
        "image-size-responsive": "off",
        "inspector-issues": "off",
        "lcp-discovery-insight": "off",
        "cls-culprits-insight": "off",
        "legacy-javascript-insight": "off",
        "network-dependency-tree-insight": "off",
        "offscreen-images": "off",
        "third-party-cookies": "off",
        "unminified-javascript": "off",
        "unsized-images": "off",
        "unused-css-rules": "off",
        "unused-javascript": "off",
        "uses-rel-preconnect": "off",
        "uses-responsive-images": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
