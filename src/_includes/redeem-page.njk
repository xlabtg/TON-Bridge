        content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    <title>{{ t.title_redeem }}</title>
    <meta name="description" content="TON Bridge HTML Mobile Template">
    <meta name="keywords" content="bootstrap, wallet, banking, fintech mobile template, cordova, phonegap, mobile, html, responsive" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="manifest" href="__manifest.json">
    <style>
        .redeem-balance-card {
            background: var(--bs-primary, #1bb2da);
            color: #fff;
            border-radius: 12px;
            padding: 20px;
            margin: 16px;
            text-align: center;
        }
        .redeem-balance-card .points-value {
            font-size: 2.5rem;
            font-weight: 700;
            line-height: 1.1;
        }
        .redeem-balance-card .points-label {
            font-size: 0.9rem;
            opacity: 0.85;
        }
        .redeem-balance-card .equiv-row {
            margin-top: 8px;
            font-size: 0.95rem;
            opacity: 0.9;
        }
        .redeem-slider-section {
            margin: 0 16px 16px;
        }
        .redeem-slider-section input[type=range] {
            width: 100%;
            accent-color: var(--bs-primary, #1bb2da);
        }
        .redeem-equiv-row {
            display: flex;
            justify-content: space-between;
            margin-top: 6px;
            font-size: 0.9rem;
            color: var(--bs-secondary-color, #6c757d);
        }
        .redeem-equiv-row span strong {
            color: var(--bs-body-color, #212529);
        }
        .redeem-min-note {
            font-size: 0.78rem;
            color: var(--bs-secondary-color, #6c757d);
            text-align: center;
            margin-top: 4px;
        }
        .toast-msg {
            display: none;
            position: fixed;
            bottom: 80px;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            color: #fff;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 0.9rem;
            z-index: 9999;
            max-width: 90vw;
            text-align: center;
        }
        .toast-msg.success { background: #1bb2da; }
        .toast-msg.error   { background: #dc3545; }
        .redeem-history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .status-badge {
            font-size: 0.75rem;
            padding: 2px 8px;
            border-radius: 12px;
            font-weight: 600;
        }
        .status-requested { background: #fff3cd; color: #856404; }
        .status-paid      { background: #d1e7dd; color: #0a3622; }
        .status-failed    { background: #f8d7da; color: #842029; }
        .status-queued    { background: #cff4fc; color: #055160; }
    </style>
</head>

<body>
