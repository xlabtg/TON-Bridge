<!doctype html>
<html lang="{{ htmlLang | default('en') }}">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport"
        content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description | default('TON Bridge HTML Mobile Template') }}">
    <meta name="keywords"
        content="{{ keywords | default('bootstrap, wallet, banking, fintech mobile template, cordova, phonegap, mobile, html, responsive') }}" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    <!-- Preconnect to third-party origins -->
    <link rel="preconnect" href="https://changenow.io" crossorigin>
    <link rel="preconnect" href="https://widget-api.changenow.io" crossorigin>
    <link rel="preconnect" href="https://tganalytics.xyz" crossorigin>
    <link rel="preconnect" href="https://mc.yandex.ru" crossorigin>
    <link rel="preconnect" href="https://telegram.org" crossorigin>
    <!-- Critical above-the-fold CSS inlined -->
    {% if criticalCss %}<style>{{ criticalCss | safe }}</style>{% endif %}
    <!-- Full stylesheet loaded asynchronously — never blocks first paint -->
    <link rel="preload" href="assets/css/style.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="assets/css/style.css"></noscript>
    <link rel="manifest" href="__manifest.json">
    {{ extraHead | safe }}
</head>

<body>
{{ content | safe }}
</body>

</html>
