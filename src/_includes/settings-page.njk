<!doctype html>
<html lang="en">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport"
        content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    <title>{{ t.title_settings }}</title>
    <meta name="description" content="TON Bridge HTML Mobile Template">
    <meta name="keywords" content="bootstrap, wallet, banking, fintech mobile template, cordova, phonegap, mobile, html, responsive" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="manifest" href="__manifest.json">
</head>

<body>

    <!-- loader -->
    <div id="loader">
        <img src="assets/img/loading-icon.png" alt="icon" class="loading-icon">
    </div>
    <!-- * loader -->

    <!-- App Header -->
    <div class="appHeader">
        <div class="left">
        </div>
        <div class="pageTitle">
            {{ t.settings_title_label }}
        </div>
    </div>
    <!-- * App Header -->

    <!-- App Capsule -->
    <div id="appCapsule">

    <div class="listview-title mt-1">{{ t.settings_theme_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div>
                        {{ t.settings_dark_mode_label }}
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input dark-mode-switch" type="checkbox" id="darkmodeSwitch">
                        <label class="form-check-label" for="darkmodeSwitch"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div class="listview-title mt-1">{{ t.settings_lang_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div>
                        {{ t.settings_lang_label }}
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input language-switch" type="checkbox" id="languageSwitch">
                        <label class="form-check-label" for="languageSwitch"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div id="wallet-section">
        <div class="listview-title mt-1">{{ t.settings_wallet_section }}</div>
        <ul class="listview image-listview text inset no-line">
            <li id="wallet-connect-item">
                <div class="item">
                    <div class="in">
                        <button id="wallet-connect-btn" class="btn btn-primary btn-sm">
                            <ion-icon name="wallet-outline"></ion-icon>
                            {{ t.settings_wallet_connect_btn }}
                        </button>
                    </div>
                </div>
            </li>
            <li id="wallet-connected-block" class="d-none">
                <div class="item">
                    <div class="in">
                        <div>
                            <strong>{{ t.settings_wallet_connected_label }}</strong><br>
                            <small id="wallet-address-display" class="text-muted" title=""></small>
                        </div>
                        <button id="wallet-replace-btn" class="btn btn-outline-secondary btn-sm ms-2">
                            {{ t.settings_wallet_replace_btn }}
                        </button>
                    </div>
                </div>
            </li>
            <li id="wallet-exchange-warning" class="d-none">
                <div class="item">
                    <div class="in">
                        <div class="alert alert-warning mb-0 py-1 px-2" role="alert" style="font-size:0.85em;">
                            <ion-icon name="warning-outline"></ion-icon>
                            {{ t.settings_wallet_exchange_warning }}
                        </div>
                    </div>
                </div>
            </li>
            <li id="wallet-disconnect-note" class="d-none">
                <div class="item">
                    <div class="in">
                        <small class="text-muted">{{ t.settings_wallet_disconnect_note }}</small>
                    </div>
                </div>
            </li>
            <li id="wallet-remove-item">
                <div class="item">
                    <div class="in">
                        <button id="wallet-remove-btn" class="btn btn-outline-danger btn-sm">
                            <ion-icon name="trash-outline"></ion-icon>
                            {{ t.settings_wallet_remove_btn }}
                        </button>
                    </div>
                </div>
            </li>
        </ul>
    </div>

</div>

<script>
    // i18n strings passed to wallet-connect.js
    window._walletI18n = {
        replaceConfirm: {{ t.settings_wallet_replace_confirm | dump | safe }},
        rateLimitError: {{ t.settings_wallet_rate_limit_error | dump | safe }},
        connectError: {{ t.settings_wallet_connect_error | dump | safe }}
    };

    // Переключение языка
    document.getElementById('languageSwitch').addEventListener('change', function() {
        if (this.checked) {
            // Переключение на страницу с английским интерфейсом
            window.location.href = '{{ t.settings_lang_checked_goto }}';
        } else {
            // Переключение на страницу с русским интерфейсом
            window.location.href = '{{ t.settings_lang_unchecked_goto }}';
        }
    });
</script>

    <!-- * App Capsule -->


    <!-- App Bottom Menu -->
    <div class="appBottomMenu">
        <a href="index{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="sync"></ion-icon>
                <strong>{{ t.nav_bridge }}</strong>
            </div>
        </a>
        <a href="index2{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="swap-horizontal-outline"></ion-icon>
                <strong>{{ t.nav_exchange }}</strong>
            </div>
        </a>
        <a href="index3{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="cash-outline"></ion-icon>
                <strong>{{ t.nav_otc }}</strong>
            </div>
        </a>
        <!-- <a href="index4{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="stats-chart"></ion-icon>
                <strong>{{ t.nav_statistics }}</strong>
            </div>
        </a> -->
        <a href="app-settings{{ t.suffix }}.html" class="item active">
            <div class="col">
                <ion-icon name="settings-outline"></ion-icon>
                <strong>{{ t.nav_settings }}</strong>
            </div>
        </a>
    </div>
    <!-- * App Bottom Menu -->

    <!-- ========= JS Files =========  -->
    <!-- Bootstrap -->
    <script src="assets/js/lib/bootstrap.bundle.min.js"></script>
    <!-- Ionicons -->
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
    <!-- Splide -->
    <script src="assets/js/plugins/splide/splide.min.js"></script>
    <!-- Base Js File -->
    <script src="assets/js/base.js"></script>
    <!-- Telegram BackButton -->
    <script src="assets/js/back-button.js"></script>
    <script>wireBackButton();</script>
    <!-- TonConnect UI (wallet linking) -->
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <script src="assets/js/wallet-connect.js"></script>


</body>

</html>
