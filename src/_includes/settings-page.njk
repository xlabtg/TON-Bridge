<!doctype html>
<html lang="en">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport"
        content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#000000">
    <title>{{ t.title_settings }}</title>
    <meta name="description" content="TON Bridge HTML Mobile Template">
    <meta name="keywords" content="bootstrap, wallet, banking, fintech mobile template, cordova, phonegap, mobile, html, responsive" />
    <link rel="icon" type="image/png" href="assets/img/favicon.png" sizes="32x32">
    <link rel="apple-touch-icon" sizes="180x180" href="assets/img/icon/192x192.png">
    <link rel="stylesheet" href="assets/css/style.css">
    <link rel="manifest" href="__manifest.json">
</head>

<body>

    <!-- loader -->
    <div id="loader">
        <img src="assets/img/loading-icon.png" alt="icon" class="loading-icon">
    </div>
    <!-- * loader -->

    <!-- App Header -->
    <div class="appHeader">
        <div class="left">
        </div>
        <div class="pageTitle">
            {{ t.settings_title_label }}
        </div>
    </div>
    <!-- * App Header -->

    <!-- App Capsule -->
    <div id="appCapsule">

    <div class="listview-title mt-1">{{ t.settings_theme_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div>
                        {{ t.settings_dark_mode_label }}
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input dark-mode-switch" type="checkbox" id="darkmodeSwitch">
                        <label class="form-check-label" for="darkmodeSwitch"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

    <div class="listview-title mt-1">{{ t.settings_lang_section }}</div>
    <ul class="listview image-listview text inset no-line">
        <li>
            <div class="item">
                <div class="in">
                    <div>
                        {{ t.settings_lang_label }}
                    </div>
                    <div class="form-check form-switch ms-2">
                        <input class="form-check-input language-switch" type="checkbox" id="languageSwitch">
                        <label class="form-check-label" for="languageSwitch"></label>
                    </div>
                </div>
            </div>
        </li>
    </ul>

</div>

<script>
    // Переключение языка
    document.getElementById('languageSwitch').addEventListener('change', function() {
        if (this.checked) {
            // Переключение на страницу с английским интерфейсом
            window.location.href = '{{ t.settings_lang_checked_goto }}';
        } else {
            // Переключение на страницу с русским интерфейсом
            window.location.href = '{{ t.settings_lang_unchecked_goto }}';
        }
    });
</script>

    <!-- * App Capsule -->


    <!-- App Bottom Menu -->
    <div class="appBottomMenu">
        <a href="index{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="sync"></ion-icon>
                <strong>{{ t.nav_bridge }}</strong>
            </div>
        </a>
        <a href="index2{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="swap-horizontal-outline"></ion-icon>
                <strong>{{ t.nav_exchange }}</strong>
            </div>
        </a>
        <a href="index3{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="cash-outline"></ion-icon>
                <strong>{{ t.nav_otc }}</strong>
            </div>
        </a>
        <!-- <a href="index4{{ t.suffix }}.html" class="item">
            <div class="col">
                <ion-icon name="stats-chart"></ion-icon>
                <strong>{{ t.nav_statistics }}</strong>
            </div>
        </a> -->
        <a href="app-settings{{ t.suffix }}.html" class="item active">
            <div class="col">
                <ion-icon name="settings-outline"></ion-icon>
                <strong>{{ t.nav_settings }}</strong>
            </div>
        </a>
    </div>
    <!-- * App Bottom Menu -->

    <!-- ========= JS Files =========  -->
    <!-- Bootstrap -->
    <script src="assets/js/lib/bootstrap.bundle.min.js"></script>
    <!-- Ionicons -->
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
    <!-- Splide -->
    <script src="assets/js/plugins/splide/splide.min.js"></script>
    <!-- Base Js File -->
    <script src="assets/js/base.js"></script>
    <!-- Telegram BackButton -->
    <script src="assets/js/back-button.js"></script>
    <script>wireBackButton();</script>
    <!-- Haptic Feedback -->
    <script src="assets/js/haptic.js"></script>
    <script>
        // Tab-bar taps
        document.querySelectorAll('.appBottomMenu .item').forEach(function (el) {
            el.addEventListener('click', function () { haptic.impact('light'); });
        });
        // Settings toggles
        document.getElementById('darkmodeSwitch').addEventListener('change', function () {
            haptic.selection();
        });
        document.getElementById('languageSwitch').addEventListener('change', function () {
            haptic.selection();
        });
    </script>
    <!-- Telegram SettingsButton - hide on settings page to avoid recursion -->
    <script src="assets/js/settings-button.js"></script>
    <script>hideSettingsButton();</script>


</body>

</html>
