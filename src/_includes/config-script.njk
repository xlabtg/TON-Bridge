{# Public runtime config (window.__TON_BRIDGE_CONFIG__), generated by the PHP
   installer (installer/src/Installer.php → tonbridge_installer_build_browser_config).
   Loaded with `defer` so it never blocks first paint (issue #187 — it was the
   sole render-blocking resource left on the Bridge / Exchange / OTC pages), and
   emitted before every other script so it stays first in the deferred execution
   order. Consumers — auth.js (reads workerBaseUrl on load), admin-access.js,
   deep-link.js, referral*.js, share-to-story.js, achievements.js, wallet-connect.js
   — read window.__TON_BRIDGE_CONFIG__ only after it has been set. #}
<script defer src="assets/js/tonbridge-config.js"></script>
