            Achievements.init();
            window.addEventListener('message', function(event) {
                if (!event.data || typeof event.data !== 'object') return;
                var type = event.data.type;
                if (
                    (type === 'change-now-widget-step' && event.data.step === 'success') ||
                    (type === 'deeplink' && event.data.value === 'success')
                ) {
                    Achievements.recordSwap(0);
                }
            });
        });
    </script>

